    "build:caap-data": "node caap/scripts/build-caap-content.mjs",
    "build:focusbc": "node focusbc/build.mjs",
    "build:caap-public": "node scripts/build-caap-public.mjs",
    "import:focusbc-case-studies": "node focusbc/scripts/import-case-studies-from-wix.mjs",
    "import:focusbc-blog": "node focusbc/scripts/import-blog-from-wix.mjs",
