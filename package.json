{
  "name": "websites-local-server",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build-pages.mjs",
    "dev": "node scripts/watch-pages.mjs",
    "start": "node scripts/start-local.mjs",
    "serve": "node scripts/start-local.mjs",
    "serve:server": "node server.mjs",
    "build:blog": "node focusbc/scripts/build-blog-posts-json.mjs",
    "build:case-studies": "node focusbc/scripts/build-case-studies-json.mjs",
